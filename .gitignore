# .gitignore
# Общее
*.log
*.tmp
.DS_Store
Thumbs.db

# Клиент (Flutter)
/client/.dart_tool/
/client/.packages
/client/build/
/client/.flutter-plugins
/client/.flutter-plugins-dependencies
/client/.idea/
/client/*.iml

# Сервер (Go)
/server/bin/
/server/tmp/
/server/data.db   # База данных не должна попадать в репозиторий